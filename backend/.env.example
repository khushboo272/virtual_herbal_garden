# ──────────────────────────────────────────────────────
# Virtual Herbal Garden — Backend Environment Variables
# Copy this file to .env and fill in all values
# ──────────────────────────────────────────────────────

# ── Server ──
NODE_ENV=development                          # development | staging | production
PORT=5000                                     # API server port
API_VERSION=v1                                # API version prefix

# ── MongoDB ──
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=herbal_garden_dev             # Database name

# ── Redis ──
REDIS_URL=redis://localhost:6379              # Redis connection URL (cache + BullMQ)

# ── JWT (RS256) ──
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ACCESS_EXPIRY=1h                          # Access token expiry
JWT_REFRESH_EXPIRY=30d                        # Refresh token expiry

# ── AWS S3 ──
AWS_S3_BUCKET=virtual-herbal-garden-media     # S3 bucket for uploads
AWS_REGION=ap-south-1                         # AWS region
AWS_ACCESS_KEY_ID=AKIA...                     # AWS IAM access key
AWS_SECRET_ACCESS_KEY=...                     # AWS IAM secret key
CDN_BASE_URL=https://cdn.example.com          # CloudFront/CDN base URL

# ── Google OAuth2 ──
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# ── AI Microservice ──
AI_SERVICE_URL=http://localhost:8000          # Python FastAPI AI service URL
AI_MODEL_VERSION=v2.3.1                       # Default ML model version

# ── Encryption ──
ENCRYPTION_KEY=a-32-byte-hex-key-for-aes256  # AES-256 key for TOTP + OAuth token encryption

# ── Email (SMTP) ──
SMTP_HOST=smtp.gmail.com                      # SMTP server host
SMTP_PORT=587                                 # SMTP port
SMTP_USER=noreply@example.com                 # SMTP username
SMTP_PASS=app-specific-password               # SMTP password
EMAIL_FROM=Virtual Herbal Garden <noreply@example.com>

# ── Frontend ──
CLIENT_URL=http://localhost:3000              # Frontend URL for CORS + OAuth redirects

# ── Rate Limiting ──
RATE_LIMIT_WINDOW_MS=60000                    # Global rate limit window (1 min)
RATE_LIMIT_MAX=100                            # Max requests per window per IP
AUTH_RATE_LIMIT_MAX=5                         # Max auth attempts per window
DETECTION_RATE_LIMIT_MAX=10                   # Max AI detections per hour per user

# ── Logging ──
LOG_LEVEL=debug                               # winston log level: error|warn|info|debug
